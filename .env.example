# GitHub Personal Access Token (optional but recommended for higher rate limits)
# Create at: https://github.com/settings/tokens
# Scopes needed: public_repo (read only)
GITHUB_TOKEN=

# App URL (used for share links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Persistent Store (GitHub repo as free DB) ──────────────────────────────
# Create a PRIVATE GitHub repo (e.g. "devtracker-data") then fill these in.
# PAT needs: repo scope (read + write contents)
# Create at: https://github.com/settings/tokens
STORE_GITHUB_TOKEN=your_pat_with_repo_scope
STORE_REPO_OWNER=
STORE_REPO_NAME=

# Salt for hashing IPs in rate limiter (any random string, keep secret)
IP_HASH_SALT=change_this_to_a_random_string
